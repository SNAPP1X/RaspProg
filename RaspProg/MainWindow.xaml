<Window x:Class="RaspProg.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расписание" Height="400" Width="600">

    <StackPanel Margin="10" HorizontalAlignment="Stretch">

        <!-- Существующие кнопки и TextBox -->
        <Button Content="Загрузить Excel"
            Click="Load_Click"
            Margin="5"
            HorizontalAlignment="Stretch"/>
        <Button Content="Сформировать занятость"
            Click="Generate_Click"
            Margin="5"
            HorizontalAlignment="Stretch"/>
        <TextBox x:Name="TeacherBox"
             Margin="5"
             Text="Имя преподавателя"
             GotFocus="TeacherBox_GotFocus"
             LostFocus="TeacherBox_LostFocus"
             HorizontalAlignment="Stretch"/>
        <Button Content="Найти преподавателя"
            Click="Find_Click"
            Margin="5"
            HorizontalAlignment="Stretch"/>
        <Button Content="Посчитать часы"
            Click="Hours_Click"
            Margin="5"
            HorizontalAlignment="Stretch"/>

        <!-- Новая кнопка для генерации файла Excel -->
        <Button Content="Сгенерировать файл Excel"
            Click="GenerateFile_Click"
            Margin="5"
            HorizontalAlignment="Stretch"/>

        <TextBlock x:Name="ResultText"
               Margin="10"
               TextWrapping="Wrap"
               HorizontalAlignment="Stretch"/>
    </StackPanel>
</Window>